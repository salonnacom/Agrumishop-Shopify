{% comment %}
  Section: Recipe Meta Widget (universal)
  File name: sections/custom-ricetta-info.liquid

  Legge i metafield della ricetta dalla risorsa corrente (product, article, page, collection, ecc.)
  Assumes you created metafields in namespace "recipe":
  - recipe.prep_time (text, ISO 8601 duration, e.g. PT10M)
  - recipe.cook_time (text, ISO 8601 duration, e.g. PT18M)
  - recipe.total_time (text, ISO 8601 duration, e.g. PT28M) optional
  - recipe.servings (number/integer)
  - recipe.difficulty (text)
  - recipe.calories (number/integer) -> kcal per serving
  - recipe.main_citrus (text)

  Funziona su qualsiasi template: product, article, page, collection, ecc.
{% endcomment %}

  {%- comment -%} Rileva automaticamente la risorsa corrente e legge i metafield {%- endcomment -%}
  {%- assign current_resource = null -%}
  {%- assign mf = null -%}
  
  {%- if product != blank -%}
    {%- assign current_resource = product -%}
    {%- assign mf = product.metafields.recipe -%}
  {%- elsif article != blank -%}
    {%- assign current_resource = article -%}
    {%- assign mf = article.metafields.recipe -%}
  {%- elsif page != blank -%}
    {%- assign current_resource = page -%}
    {%- assign mf = page.metafields.recipe -%}
  {%- elsif collection != blank -%}
    {%- assign current_resource = collection -%}
    {%- assign mf = collection.metafields.recipe -%}
  {%- elsif blog != blank -%}
    {%- assign current_resource = blog -%}
    {%- assign mf = blog.metafields.recipe -%}
  {%- endif -%}

  {%- comment -%} Leggi i metafield o usa dati di esempio per l'anteprima editor {%- endcomment -%}
  {%- if mf != blank and current_resource != blank -%}
    {%- assign prep_raw = mf.prep_time.value | default: mf.prep_time -%}
    {%- assign cook_raw = mf.cook_time.value | default: mf.cook_time -%}
    {%- assign total_raw = mf.total_time.value | default: mf.total_time -%}
    {%- assign servings = mf.servings.value | default: mf.servings -%}
    {%- assign difficulty = mf.difficulty.value | default: mf.difficulty -%}
    {%- assign calories = mf.calories.value | default: mf.calories -%}
    {%- assign main_citrus = mf.main_citrus.value | default: mf.main_citrus -%}
  {%- else -%}
    {%- comment -%} Usa dati di esempio per l'anteprima dell'editor {%- endcomment -%}
    {%- assign prep_raw = section.settings.demo_prep_time | default: 'PT15M' -%}
    {%- assign cook_raw = section.settings.demo_cook_time | default: 'PT30M' -%}
    {%- assign total_raw = section.settings.demo_total_time | default: 'PT45M' -%}
    {%- assign servings = section.settings.demo_servings | default: 4 -%}
    {%- assign difficulty = section.settings.demo_difficulty | default: 'Media' -%}
    {%- assign calories = section.settings.demo_calories | default: 250 -%}
    {%- assign main_citrus = section.settings.demo_main_citrus | default: 'Limone' -%}
  {%- endif -%}

  {%- comment -%} Helpers: parse ISO 8601 duration like PT1H20M, PT45M, PT2H {%- endcomment -%}
  {%- capture durations_json -%}
  {
    "prep":"{{ prep_raw | default: '' | escape }}",
    "cook":"{{ cook_raw | default: '' | escape }}",
    "total":"{{ total_raw | default: '' | escape }}"
  }
  {%- endcapture -%}

  {%- comment -%} Determine if we should render at all {%- endcomment -%}
  {%- assign has_any = false -%}
  {%- if prep_raw != blank or cook_raw != blank or total_raw != blank or servings != blank or difficulty != blank or calories != blank or main_citrus != blank -%}
    {%- assign has_any = true -%}
  {%- endif -%}

  {%- comment -%} Mostra sempre la sezione nell'anteprima, anche senza dati {%- endcomment -%}
  {%- if has_any or current_resource == blank -%}
    <section
      class="recipe-meta section-{{ section.id }}"
      aria-label="{{ section.settings.aria_label | escape }}"
      data-durations='{{ durations_json | strip_newlines | replace: "  ", "" }}'
    >
      <div class="page-width">
        <div class="recipe-meta__card">
          {% if section.settings.heading != blank %}
            <h2 class="recipe-meta__heading">{{ section.settings.heading }}</h2>
          {% endif %}

          <div class="recipe-meta__grid" role="list">
            {% if section.settings.show_total_time and total_raw != blank %}
              <div class="recipe-meta__item" role="listitem">
                <span class="recipe-meta__icon" aria-hidden="true">⏱️</span>
                <div class="recipe-meta__text">
                  <span class="recipe-meta__label">{{ section.settings.label_total_time }}</span>
                  <span class="recipe-meta__value" data-duration="total"></span>
                </div>
              </div>
            {% endif %}

            {% if section.settings.show_prep_time and prep_raw != blank %}
              <div class="recipe-meta__item" role="listitem">
                <span class="recipe-meta__icon" aria-hidden="true">🧑‍🍳</span>
                <div class="recipe-meta__text">
                  <span class="recipe-meta__label">{{ section.settings.label_prep_time }}</span>
                  <span class="recipe-meta__value" data-duration="prep"></span>
                </div>
              </div>
            {% endif %}

            {% if section.settings.show_cook_time and cook_raw != blank %}
              <div class="recipe-meta__item" role="listitem">
                <span class="recipe-meta__icon" aria-hidden="true">🔥</span>
                <div class="recipe-meta__text">
                  <span class="recipe-meta__label">{{ section.settings.label_cook_time }}</span>
                  <span class="recipe-meta__value" data-duration="cook"></span>
                </div>
              </div>
            {% endif %}

            {% if section.settings.show_servings and servings != blank %}
              <div class="recipe-meta__item" role="listitem">
                <span class="recipe-meta__icon" aria-hidden="true">👥</span>
                <div class="recipe-meta__text">
                  <span class="recipe-meta__label">{{ section.settings.label_servings }}</span>
                  <span class="recipe-meta__value">{{ servings }}</span>
                </div>
              </div>
            {% endif %}

            {% if section.settings.show_difficulty and difficulty != blank %}
              <div class="recipe-meta__item" role="listitem">
                <span class="recipe-meta__icon" aria-hidden="true">📊</span>
                <div class="recipe-meta__text">
                  <span class="recipe-meta__label">{{ section.settings.label_difficulty }}</span>
                  <span class="recipe-meta__value">{{ difficulty }}</span>
                </div>
              </div>
            {% endif %}

            {% if section.settings.show_calories and calories != blank %}
              <div class="recipe-meta__item" role="listitem">
                <span class="recipe-meta__icon" aria-hidden="true">⚡</span>
                <div class="recipe-meta__text">
                  <span class="recipe-meta__label">{{ section.settings.label_calories }}</span>
                  <span class="recipe-meta__value">{{ calories }} <span class="recipe-meta__unit">kcal</span></span>
                </div>
              </div>
            {% endif %}

            {% if section.settings.show_main_citrus and main_citrus != blank %}
              <div class="recipe-meta__item" role="listitem">
                <span class="recipe-meta__icon" aria-hidden="true">🍊</span>
                <div class="recipe-meta__text">
                  <span class="recipe-meta__label">{{ section.settings.label_main_citrus }}</span>
                  <span class="recipe-meta__value">{{ main_citrus }}</span>
                </div>
              </div>
            {% endif %}
          </div>

          {% if section.settings.note != blank %}
            <p class="recipe-meta__note">{{ section.settings.note }}</p>
          {% endif %}
        </div>
      </div>
    </section>

    <style>
      .section-{{ section.id }} .recipe-meta__card{
        background: rgb(var(--color-background));
        border: 1px solid rgba(var(--color-foreground), .08);
        border-radius: 12px;
        padding: 18px;
      }
      .section-{{ section.id }} .recipe-meta__heading{
        margin: 0 0 12px 0;
        font-size: calc(var(--font-heading-scale) * 1.2rem);
        line-height: 1.2;
      }
      .section-{{ section.id }} .recipe-meta__grid{
        display: grid;
        gap: 10px;
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
      @media (min-width: 750px){
        .section-{{ section.id }} .recipe-meta__grid{
          grid-template-columns: repeat({{ section.settings.columns_desktop }}, minmax(0, 1fr));
        }
      }
      .section-{{ section.id }} .recipe-meta__item{
        display: flex;
        gap: 10px;
        align-items: flex-start;
        padding: 10px 12px;
        border-radius: 10px;
        background: rgba(var(--color-foreground), .03);
      }
      .section-{{ section.id }} .recipe-meta__icon{
        font-size: 18px;
        line-height: 1;
        margin-top: 2px;
      }
      .section-{{ section.id }} .recipe-meta__text{
        display: flex;
        flex-direction: column;
        min-width: 0;
      }
      .section-{{ section.id }} .recipe-meta__label{
        font-size: 12px;
        letter-spacing: .02em;
        opacity: .75;
      }
      .section-{{ section.id }} .recipe-meta__value{
        font-size: 14px;
        font-weight: 600;
        line-height: 1.3;
        word-break: break-word;
      }
      .section-{{ section.id }} .recipe-meta__unit{
        font-weight: 500;
        opacity: .85;
      }
      .section-{{ section.id }} .recipe-meta__note{
        margin: 12px 0 0 0;
        font-size: 12px;
        opacity: .75;
      }
    </style>

    <script>
      (function () {
        const root = document.querySelector('.recipe-meta.section-{{ section.id }}');
        if (!root) return;

        // Parse durations JSON safely
        let durations = {};
        try {
          durations = JSON.parse(root.getAttribute('data-durations') || '{}');
        } catch (e) {}

        // ISO 8601 duration parser (PT#H#M)
        function formatDuration(iso) {
          if (!iso || typeof iso !== 'string') return '';
          const s = iso.trim().toUpperCase();
          const m = s.match(/^P(T(?:(\d+)H)?(?:(\d+)M)?(?:(\d+)S)?)$/);
          if (!m) return iso; // fallback: show raw if not parseable
          const hours = parseInt(m[2] || '0', 10);
          const mins  = parseInt(m[3] || '0', 10);
          // seconds not used in UI, but could be added if needed
          if (hours && mins) return `${hours}h ${mins}m`;
          if (hours) return `${hours}h`;
          if (mins) return `${mins} min`;
          return '—';
        }

        root.querySelectorAll('[data-duration]').forEach((el) => {
          const key = el.getAttribute('data-duration');
          const raw = durations[key] || '';
          const formatted = formatDuration(raw);
          el.textContent = formatted || raw || '';
        });
      })();
    </script>
  {% endif %}

{% schema %}
{
  "name": "Recipe Meta Widget",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Titolo",
      "default": "Info ricetta"
    },
    {
      "type": "text",
      "id": "aria_label",
      "label": "ARIA label",
      "default": "Informazioni ricetta"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Colonne desktop",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 6
    },

    { "type": "header", "content": "Mostra campi" },
    { "type": "checkbox", "id": "show_total_time", "label": "Tempo totale", "default": true },
    { "type": "checkbox", "id": "show_prep_time", "label": "Tempo preparazione", "default": true },
    { "type": "checkbox", "id": "show_cook_time", "label": "Tempo cottura", "default": true },
    { "type": "checkbox", "id": "show_servings", "label": "Porzioni", "default": true },
    { "type": "checkbox", "id": "show_difficulty", "label": "Difficoltà", "default": true },
    { "type": "checkbox", "id": "show_calories", "label": "Calorie", "default": true },
    { "type": "checkbox", "id": "show_main_citrus", "label": "Agrume principale", "default": true },

    { "type": "header", "content": "Etichette" },
    { "type": "text", "id": "label_total_time", "label": "Label tempo totale", "default": "Tempo totale" },
    { "type": "text", "id": "label_prep_time", "label": "Label preparazione", "default": "Preparazione" },
    { "type": "text", "id": "label_cook_time", "label": "Label cottura", "default": "Cottura" },
    { "type": "text", "id": "label_servings", "label": "Label porzioni", "default": "Porzioni" },
    { "type": "text", "id": "label_difficulty", "label": "Label difficoltà", "default": "Difficoltà" },
    { "type": "text", "id": "label_calories", "label": "Label calorie", "default": "Calorie (per porzione)" },
    { "type": "text", "id": "label_main_citrus", "label": "Label agrume principale", "default": "Agrume principale" },

    {
      "type": "text",
      "id": "note",
      "label": "Nota (opzionale)",
      "default": "Valori indicativi. Le calorie possono variare in base agli ingredienti utilizzati."
    },

    { "type": "header", "content": "Dati di esempio (per anteprima editor)" },
    { "type": "text", "id": "demo_prep_time", "label": "Tempo preparazione esempio", "default": "PT15M", "info": "Formato ISO 8601 (es. PT15M, PT1H30M)" },
    { "type": "text", "id": "demo_cook_time", "label": "Tempo cottura esempio", "default": "PT30M", "info": "Formato ISO 8601 (es. PT30M, PT2H)" },
    { "type": "text", "id": "demo_total_time", "label": "Tempo totale esempio", "default": "PT45M", "info": "Formato ISO 8601 (es. PT45M, PT3H)" },
    { "type": "number", "id": "demo_servings", "label": "Porzioni esempio", "default": 4 },
    { "type": "text", "id": "demo_difficulty", "label": "Difficoltà esempio", "default": "Media" },
    { "type": "number", "id": "demo_calories", "label": "Calorie esempio", "default": 250 },
    { "type": "text", "id": "demo_main_citrus", "label": "Agrume principale esempio", "default": "Limone" }
  ],
  "presets": [
    { 
        "name": "Recipe Meta Widget",
        "category": "Custom"
    }
  ]
}
{% endschema %}
